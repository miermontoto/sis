{
  "name": "@sis/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts && mkdir -p dist/db && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@sis/shared": "workspace:*",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "better-sqlite3": "^11.8.0",
    "drizzle-orm": "^0.38.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
